<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GLID | Preload de Elite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --gold-light: #E8D5C4; 
            --gold-base: #B8A38E;  
            --gold-deep: #8D7A65;  
            --color-gunmetal: #2C2C2C;
            --color-cashmere: #F5F5F3;
            
            /* Variáveis para o Efeito Lanterna */
            --mouse-x: 50%;
            --mouse-y: 50%;
        }

        /* Foundation: Metal Polido com Efeito Lanterna */
        #preloader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* O gradiente base agora reage à posição do rato */
            background: radial-gradient(
                circle at var(--mouse-x) var(--mouse-y),
                var(--gold-light) 0%,
                var(--gold-base) 30%,
                var(--gold-deep) 100%
            );
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            overflow: hidden;
            cursor: none; /* Ocultamos para usar o feixe de luz como guia */
        }

        /* Camada de Monogramas (Wallpaper de Luxo) */
        .monogram-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('https://glid.carrd.co/assets/images/image03.png?v=951bca55');
            background-size: 80px; /* Tamanho delicado do monograma */
            background-repeat: repeat;
            opacity: 0.04; /* Quase invisível, sentido apenas no brilho */
            mix-blend-mode: multiply;
            pointer-events: none;
        }

        /* Brilho da Lanterna (Foco de Luz Dinâmico) */
        .lantern-glow {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(
                600px circle at var(--mouse-x) var(--mouse-y),
                rgba(232, 213, 196, 0.4),
                transparent 40%
            );
            pointer-events: none;
            z-index: 1;
        }

        /* Container da Logo */
        .logo-container {
            position: relative;
            width: 200px;
            margin-bottom: 3rem;
            z-index: 10;
        }

        .logo-base {
            width: 100%;
            height: auto;
            display: block;
            filter: drop-shadow(0 20px 30px rgba(0,0,0,0.15));
        }

        /* Reflexo Mascarado (Metallic Sweep) */
        .logo-shimmer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                110deg,
                transparent 20%,
                rgba(255, 255, 255, 0.7) 50%,
                transparent 80%
            );
            background-size: 200% 100%;
            -webkit-mask-image: url('https://glid.carrd.co/assets/images/image03.png?v=951bca55');
            mask-image: url('https://glid.carrd.co/assets/images/image03.png?v=951bca55');
            -webkit-mask-size: contain;
            mask-size: contain;
            -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
            animation: metallicSweep 4s infinite ease-in-out;
        }

        @keyframes metallicSweep {
            0% { background-position: 200% 0; opacity: 0; }
            15% { opacity: 1; }
            45% { background-position: -200% 0; opacity: 1; }
            60%, 100% { background-position: -200% 0; opacity: 0; }
        }

        /* A Costura Digital - Agora como um detalhe de alfaiataria */
        .stitch-container {
            position: relative;
            width: 140px;
            height: 1px;
            background-color: rgba(44, 44, 44, 0.1); 
            overflow: hidden;
            z-index: 10;
        }

        .stitch-line {
            position: absolute;
            width: 100%;
            height: 100%;
            background: var(--color-cashmere);
            box-shadow: 0 0 15px var(--gold-light);
            animation: stitchFlow 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1);
        }

        @keyframes stitchFlow {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        .technical-label {
            color: var(--color-gunmetal);
            opacity: 0.5;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.8em;
            margin-top: 2rem;
            font-weight: 600;
            z-index: 10;
        }
    </style>
</head>
<body style="margin: 0; overflow: hidden;">

    <div id="preloader">
        <!-- Camadas de Textura e Luz -->
        <div class="monogram-overlay"></div>
        <div class="lantern-glow"></div>

        <div class="flex flex-col items-center">
            <!-- Logo Container -->
            <div class="logo-container">
                <img src="https://glid.carrd.co/assets/images/image03.png?v=951bca55" alt="GLID" class="logo-base">
                <div class="logo-shimmer"></div>
            </div>
            
            <!-- A Costura -->
            <div class="stitch-container">
                <div class="stitch-line"></div>
            </div>
            
            <span class="technical-label">Performance Radical</span>
        </div>
    </div>

    <script>
        const preloader = document.getElementById('preloader');

        // Lógica da Lanterna: Segue o movimento do rato e do toque
        const handleMove = (e) => {
            const x = e.clientX || (e.touches && e.touches[0].clientX);
            const y = e.clientY || (e.touches && e.touches[0].clientY);
            
            if (x && y) {
                const percentX = (x / window.innerWidth) * 100;
                const percentY = (y / window.innerHeight) * 100;
                
                preloader.style.setProperty('--mouse-x', `${percentX}%`);
                preloader.style.setProperty('--mouse-y', `${percentY}%`);
            }
        };

        window.addEventListener('mousemove', handleMove);
        window.addEventListener('touchmove', handleMove);

        /**
         * MODO DE EDIÇÃO:
         * O preloader não sumirá. Teste a interação com o rato/dedo 
         * para ver a lanterna revelando o monograma no fundo metálico.
         */
    </script>
</body>
</html>
